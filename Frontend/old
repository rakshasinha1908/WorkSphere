html 
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SignIn To WorkSphere</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container-wrapper" id="containerWrapper">
        <!-- Left Side (Options) -->
        <div class="container">
            <h1>Welcome</h1>
            <h2>SignIn To WorkSphere</h2>
    
            <div class="card" onclick="showLoginForm('employee')">
                <div class="card-content">
                    <img src="employee-icon.png" alt="Employee Icon">
                    <span>Employee</span>
                </div>
                <span class="arrow">→</span>
            </div>
    
            <div class="card" onclick="showLoginForm('employer')">
                <div class="card-content">
                    <img src="employer-icon.png" alt="Employer Icon">
                    <span>Employer</span>
                </div>
                <span class="arrow">→</span>
            </div>
        </div>
    
        <!-- Right Side (Login Forms) -->
        <div class="login-section">
            <div id="employeeLogin" class="login-form hidden">
                <h2>Login as Employee</h2>
                <label for="employeeEmail">Employee ID/Email</label>
                <input type="text" id="employeeEmail" placeholder="employee1208">
    
                <label for="employeePassword">Password</label>
                <input type="password" id="employeePassword" placeholder="************">
    
                <a href="#" class="forgot">Forgot Password?</a>
                <button class="login-btn">LOGIN <img src="login-icon.png" alt="Login Icon"></button>
            </div>
    
            <div id="employerLogin" class="login-form hidden">
                <h2>Login as Employer</h2>
                <label for="employerEmail">Admin ID/Email</label>
                <input type="text" id="employerEmail" placeholder="admin@company.com">
    
                <label for="employerPassword">Password</label>
                <input type="password" id="employerPassword" placeholder="************">
    
                <a href="#" class="forgot">Forgot Password?</a>
                <button class="login-btn">LOGIN <img src="login-icon.png" alt="Login Icon"></button>
            </div>
        </div>
    </div>
    
    
    <script src="script1.js"></script>
</body>
</html>


css 
body {
    font-family: Arial, sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100vh;
    background-color: #f4f4f4;
    margin: 0;
}

.container-wrapper {
    display: flex;
    justify-content: center; 
    align-items: center;
    width: 80%;
    max-width: 900px;
    transition: all 0.5s ease-in-out;
    position: relative;
}

.container-wrapper.shifted {
    justify-content: flex-start;
    width: 100%;  
}

.container {
    flex: 1; 
    text-align: left;
    transition: all 0.5s ease-in-out;
}

.container-wrapper.shifted .container {
    text-align: left;
}

.login-section {
    flex: 1;
    display: flex;
    justify-content: center;
}

.hidden {
    display: none;
}

.login-form {
    background-color: #d0e7ff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.2);
    width: 280px;
}


h1 {
    font-size: 24px;
    font-weight: bold;
    margin-bottom: 10px;
}

h2 {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 20px;
}

.card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 340px;
    height: 50px;
    padding: 12px;
    background: white;
    border: 2px solid #ddd;
    border-radius: 12px;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    margin-bottom: 12px;
    transition: transform 0.2s ease-in-out;
}

.card:hover {
    transform: scale(1.05);
}

.card-content {
    display: flex;
    align-items: center;
    gap: 10px;
}

.card img {
    width: 40px;
    height: 40px;
}

.arrow {
    font-size: 20px;
    font-weight: bold;
}

.login-form {
    display: flex;
    flex-direction: column;
    background-color: #d0e7ff;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 2px 2px 10px rgba(0, 0, 0, 0.2);
    text-align: left;
    width: 280px;
    margin-top: 20px;
}

.hidden {
    display: none;
}

.login-form h2 {
    font-size: 18px;
    font-weight: bold;
    margin-bottom: 10px;
}

.login-form label {
    font-size: 14px;
    font-weight: bold;
    margin-top: 5px;
}

.login-form input {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    margin-bottom: 10px;
    border: 1px solid #999;
    border-radius: 5px;
}

.forgot {
    font-size: 12px;
    color: #0044cc;
    text-decoration: none;
    text-align: right;
    display: block;
    margin-bottom: 10px;
}

.login-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: navy;
    color: white;
    font-weight: bold;
    padding: 8px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
}

.login-btn img {
    width: 16px;
    height: 16px;
    margin-left: 5px;
}

js
function showLoginForm(userType) {
    console.log("Clicked:", userType); 

    // ✅ Hide both login forms initially
    document.getElementById("employeeLogin").classList.add("hidden");
    document.getElementById("employerLogin").classList.add("hidden");

    // ✅ Show selected login form
    if (userType === "employee") {
        document.getElementById("employeeLogin").classList.remove("hidden");
    } else if (userType === "employer") {
        document.getElementById("employerLogin").classList.remove("hidden");
    }

    // ✅ Shift container to left & right
    document.getElementById("containerWrapper").classList.add("shifted");
}
 